NODE_ENV=development
PORT=3000
JWT_SECRET=preotrade-fx-secret-key-change-in-production-2024
DB_PATH=./data/preotrade.db

# PayHero Configuration (Set these in Netlify Dashboard)
# Go to: Site settings → Environment variables
# PAYHERO_SECRET_KEY=your_key_here
# PAYHERO_ACCOUNT_ID=your_id_here
# PAYHERO_CALLBACK_URL=https://www.preocrypto.com/webhook/payhero

# Supabase Configuration (for persistent database storage)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
